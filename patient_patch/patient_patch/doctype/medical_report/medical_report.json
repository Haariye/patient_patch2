{
  "doctype": "DocType",
  "name": "Medical Report",
  "module": "Patient Patch",
  "custom": 1,
  "beta": 0,
  "istable": 0,
  "is_submittable": 1,
  "sort_field": "modified",
  "sort_order": "desc",
  "default_print_format": "Medical Report Print",
  "autoname": "field:ref_no",
  "title_field": "ref_no",
  "search_fields": "patient, patient_name, ref_no",
  "permissions": [
    {
      "role": "System Manager",
      "permlevel": 0,
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1,
      "amend": 1,
      "print": 1
    },
    {
      "role": "Healthcare Practitioner",
      "permlevel": 0,
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1,
      "print": 1
    }
  ],
  "fields": [
    {
      "fieldname": "ref_no",
      "label": "Reference Number",
      "fieldtype": "Data",
      "reqd": 1,
      "unique": 0,
      "in_list_view": 1
    },
    {
      "fieldname": "patient",
      "label": "Patient",
      "fieldtype": "Link",
      "options": "Patient",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "patient_name",
      "label": "Patient Name",
      "fieldtype": "Data",
      "read_only": 1,
      "fetch_from": "patient.patient_name"
    },
    {
      "fieldname": "patient_id",
      "label": "Patient ID",
      "fieldtype": "Data",
      "read_only": 1,
      "fetch_from": "patient.name"
    },
    {
      "fieldname": "age",
      "label": "Age",
      "fieldtype": "Data",
      "read_only": 1,
      "fetch_from": "patient.age"
    },
    {
      "fieldname": "sex",
      "label": "Sex",
      "fieldtype": "Data",
      "read_only": 1,
      "fetch_from": "patient.sex"
    },
    {
      "fieldname": "report_date",
      "label": "Report Date",
      "fieldtype": "Date",
      "default": "today",
      "reqd": 1
    },
    {
      "fieldname": "due_date",
      "label": "Due Date",
      "fieldtype": "Date"
    },
    {
      "fieldname": "diagnosis",
      "label": "Diagnosis",
      "fieldtype": "Small Text",
      "reqd": 0
    },
    {
      "fieldname": "treatment",
      "label": "Treatment",
      "fieldtype": "Small Text",
      "reqd": 0
    },
    {
      "fieldname": "recommendation",
      "label": "Recommendations",
      "fieldtype": "Small Text",
      "reqd": 0
    },
    {
      "fieldname": "doctor",
      "label": "Doctor",
      "fieldtype": "Link",
      "options": "Healthcare Practitioner"
    }
  ],
  "allow_import": 1,
  "allow_rename": 1,
  "track_changes": 1
}